# ============================================================================
# hotBrief — environment variables
# ----------------------------------------------------------------------------
# Copy this file to .env and fill in real credentials.
# .env is gitignored; never commit real secrets.
# ============================================================================

# ServerChan SCT key — sign up at https://sct.ftqq.com
SERVERCHAN_SCT_KEY=SCT_REPLACE_ME

# LLM provider credentials (OpenAI-compatible protocol)
# Pick one provider and set both KEY and BASE_URL accordingly:
#
#   DeepSeek (recommended, low cost):
#     LLM_BASE_URL=https://api.deepseek.com
#
#   Moonshot Kimi:
#     LLM_BASE_URL=https://api.moonshot.cn/v1
#
#   Alibaba Qwen (DashScope OpenAI-compatible):
#     LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
#
#   OpenAI:
#     LLM_BASE_URL=https://api.openai.com/v1
#
# For Anthropic Claude, use the official anthropic SDK separately;
# see docs for migration notes.
LLM_API_KEY=sk-REPLACE_ME
LLM_BASE_URL=https://api.deepseek.com

# Optional: outbound HTTP proxy URI for the RSSHub container only.
# Many RSSHub routes (Reddit, Hacker News, Lobsters, Twitter via Nitter)
# fetch foreign sites; from networks where those are slow or blocked,
# set a reachable proxy here. Leave empty to disable.
#
# Examples:
#   RSSHUB_PROXY_URI=http://host.docker.internal:1080  (Docker Desktop, host's localhost)
#   RSSHUB_PROXY_URI=http://10.0.0.5:1080              (proxy on the LAN)
RSSHUB_PROXY_URI=

# Optional: outbound HTTP proxy used by the aggregator's direct-RSS fetcher.
# When set, all rss:feeds[].url requests go through this proxy. Internal
# calls to DailyHotApi and RSSHub stay on the container network (HTTP
# only) and are unaffected. Use the same value as RSSHUB_PROXY_URI
# unless you have a reason to differ.
#
# FOREIGN_HTTPS_PROXY=http://10.0.0.5:1080
FOREIGN_HTTPS_PROXY=
